<Window x:Class="CyberBotApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot"
        Height="750"
        Width="1000"
        Background="#101820">

    <Grid Margin="10">

        <TabControl Background="#101820" Foreground="White">

            <!-- ================= CHAT TAB ================= -->
            <TabItem Header="Chat">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="CYBERBOT CHAT"
                               FontSize="26"
                               Foreground="Cyan"
                               HorizontalAlignment="Center"
                               Margin="0,10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10">
                        <TextBlock Text="Username:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <TextBox x:Name="UsernameBox"
                                 Width="200"
                                 Height="30"
                                 Text="User"/>
                    </StackPanel>

                    <TextBox x:Name="ChatBox"
                             Grid.Row="2"
                             Background="#1B1B1B"
                             Foreground="White"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"/>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10">

                        <TextBox x:Name="UserInputBox"
                                 Width="750"
                                 Height="35"
                                 Margin="0,0,10,0"/>

                        <Button Content="Send"
                                Width="150"
                                Height="35"
                                Click="SendButton_Click"/>
                    </StackPanel>

                </Grid>
            </TabItem>

            <!-- ================= TASK TAB ================= -->
            <TabItem Header="Task Assistant">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>

                        <TextBox x:Name="TaskTitleBox"
                                 Height="30"
                                 Margin="0,5"
                                 ToolTip="Task Title"/>

                        <TextBox x:Name="TaskDescriptionBox"
                                 Height="60"
                                 Margin="0,5"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 ToolTip="Task Description"/>

                        <DatePicker x:Name="ReminderDatePicker"/>
                    </StackPanel>

                    <ListBox x:Name="TaskListBox"
                             Grid.Row="2"
                             Margin="0,10"
                             Background="#1B1B1B"
                             Foreground="White"/>

                    <StackPanel Grid.Row="3" Orientation="Horizontal">

                        <Button Content="Add Task"
                                Width="120"
                                Margin="5"
                                Click="AddTaskButton_Click"/>

                        <Button Content="Delete"
                                Width="120"
                                Margin="5"
                                Click="DeleteTaskButton_Click"/>

                        <Button Content="Complete"
                                Width="120"
                                Margin="5"
                                Click="CompleteTaskButton_Click"/>

                        <Button Content="Refresh"
                                Width="120"
                                Margin="5"
                                Click="RefreshTasksButton_Click"/>
                    </StackPanel>

                </Grid>
            </TabItem>

            <!-- ================= QUIZ TAB ================= -->
            <TabItem Header="Quiz">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="QuestionText"
                               FontSize="18"
                               Foreground="White"
                               TextWrapping="Wrap"
                               Margin="0,10"/>

                    <RadioButton x:Name="OptionA"
                                 GroupName="QuizOptions"
                                 Grid.Row="1"
                                 Foreground="White"
                                 Margin="0,5"/>

                    <RadioButton x:Name="OptionB"
                                 GroupName="QuizOptions"
                                 Grid.Row="2"
                                 Foreground="White"
                                 Margin="0,5"/>

                    <RadioButton x:Name="OptionC"
                                 GroupName="QuizOptions"
                                 Grid.Row="3"
                                 Foreground="White"
                                 Margin="0,5"/>

                    <RadioButton x:Name="OptionD"
                                 GroupName="QuizOptions"
                                 Grid.Row="4"
                                 Foreground="White"
                                 Margin="0,5"/>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,10">

                        <Button Content="Start Quiz"
                                Width="120"
                                Margin="5"
                                Click="StartQuizButton_Click"/>

                        <Button Content="Next"
                                Width="120"
                                Margin="5"
                                Click="NextQuestionButton_Click"/>

                        <Label x:Name="ScoreLabel"
                               Content="Score: 0"
                               Foreground="White"
                               Margin="10,0,0,0"/>
                    </StackPanel>

                </Grid>
            </TabItem>

            <!-- ================= ACTIVITY LOG ================= -->
            <TabItem Header="Activity Log">

                <ListBox x:Name="ActivityLogListBox"
                         Background="#1B1B1B"
                         Foreground="White"/>

            </TabItem>

        </TabControl>

    </Grid>
</Window>
